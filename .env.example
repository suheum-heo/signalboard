# Supabase — Next.js (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — Python pipeline
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # for pipeline writes (bypasses RLS)

# KRX data portal — free account at data.krx.co.kr
KRX_ID=your-krx-id
KRX_PW=your-krx-password

# Telegram — create bot via @BotFather; get chat_id from /getUpdates after sending a message
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
